{
  "name": "calendar-booking-mock",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Prism mock server for the Calendar Booking API contract (api.tsp)",
  "scripts": {
    "link-modules": "node ./scripts/link-modules.mjs",
    "gen": "npm run link-modules && tsp compile ./main.tsp --config ./tspconfig.yaml --output-dir ./generated",
    "mock": "prism mock ./generated/@typespec/openapi3/openapi.yaml --port 4010 --dynamic --cors",
    "dev": "npm run gen && npm run mock"
  },
  "devDependencies": {
    "@stoplight/prism-cli": "^5.12.0",
    "@typespec/compiler": "^0.65.0",
    "@typespec/http": "^0.65.0",
    "@typespec/openapi3": "^0.65.0"
  }
}
